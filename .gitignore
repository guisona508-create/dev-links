# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# Local history (plugins do VS Code)
.history/

# Arquivos de log de erros de sistema
thumbs.db

# pastas de cache de ferramentas de lintin/formatação
.eslintcache

# Md
*.md
!README.md